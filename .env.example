# Скопіюйте у .env.local для локальної розробки: cp .env.example .env.local
# На Vercel: Settings → Environment Variables (увімкніть Preview + Production для кожної).

# --- Firebase (клієнт, читання в браузері) — з Firebase Console → Project settings → Your apps → Web ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Пароль адміна перевіряється на сервері (див. /api/tournament/admin-verify).
# У діалозі вводьте той самий рядок, що й TOURNAMENT_ADMIN_SECRET (NEXT_PUBLIC_ADMIN_PASSWORD не обов’язковий).

# --- Firebase Admin (серверні записи /api/tournament/write) ---
# Локально: покладіть ключ у service-account.json у корінь проєкту — файл підхопиться автоматично (пріоритет вище за FIREBASE_SERVICE_ACCOUNT_JSON).
# Якщо рядок у FIREBASE_SERVICE_ACCOUNT_JSON битий — приберіть цей рядок або виправте JSON.
# Опційно: FIREBASE_SERVICE_ACCOUNT_PATH=інший-файл.json
# На Vercel (файлу немає): npm run firebase:env-one-line
# Найстабільніше: FIREBASE_SERVICE_ACCOUNT_JSON_B64 = тільки base64-рядок (без лапок).
# Або FIREBASE_SERVICE_ACCOUNT_JSON = один рядок JSON (без переносів).
# FIREBASE_SERVICE_ACCOUNT_JSON_B64=
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Секрет для x-admin-secret; у діалозі адміна вводите той самий рядок (без лапок у .env).
TOURNAMENT_ADMIN_SECRET=

# --- Google AI / Gemini (асистент + AI-імпорт розкладу) — ключ з https://aistudio.google.com/ → Get API key ---
# Скопіюйте рядок у .env.local і вставте ключ після = (без лапок). У коді ключ не зберігається.
GEMINI_API_KEY=
# Альтернативні імена ключа, якщо зручніше:
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_AI_API_KEY=
# За замовчуванням: gemini-2.5-flash-lite (див. lib/gemini-model.ts). Якщо «quota exceeded» — перевірте білінг або спробуйте:
# GEMINI_MODEL=gemini-2.5-flash
